# ─────────────────────────────────────────────────────────────────────────────
# MOSAIC-FL — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores para o seu ambiente.
# O .env real está no .gitignore e nunca deve ser commitado.
#
# IMPORTANTE: nunca colocar comentário na mesma linha do valor (CHAVE=valor # nota).
# O Makefile carrega .env via `include` (ver topo do Makefile) — Make não separa
# comentário inline do valor, então "CHAVE=valor   # nota" vira literalmente
# "valor   " (com os espaços) na variável exportada. Comentário sempre em linha
# própria, acima do valor.
# ─────────────────────────────────────────────────────────────────────────────

# ── TLS (gRPC seguro entre servidor e clientes) ───────────────────────────────
# Omitir para rodar sem TLS (adequado para rede local de desenvolvimento).
# Para habilitar: gere os certificados com  bash scripts/gen_certs.sh  e aponte aqui.
#
# Servidor precisa de: ca.crt, server.crt, server.key
# Cliente precisa de:  ca.crt (apenas)
#
# FL_TLS_CERT_DIR=/caminho/para/certs

# ── Servidor Flower ───────────────────────────────────────────────────────────
# Endereço que o servidor escuta.
FL_SERVER_ADDRESS=0.0.0.0:8080
# Mínimo de clientes para iniciar round.
FL_MIN_AVAILABLE_CLIENTS=3
# Diretório para salvar checkpoints do modelo.
FL_CHECKPOINT_DIR=checkpoints
# Diretório de logs do servidor.
FL_LOG_DIR=logs

# ── Cliente Flower ────────────────────────────────────────────────────────────
# Identificador único do cliente/hospital.
FL_CLIENT_ID=hospital_a
# Segundos entre tentativas de reconexão.
FL_RECONNECT_DELAY=30
# Segundos entre heartbeats ao registry.
FL_HEARTBEAT_INTERVAL=60

# ── Observabilidade / Métricas ────────────────────────────────────────────────
# Métricas Prometheus disponíveis em GET http://<servidor>:8081/metrics
# (scrapeável por Prometheus, VictoriaMetrics, Datadog Agent, Grafana Alloy)
#
# Para o scheduler (CronJob — termina antes do scrape): configure um Pushgateway
# FL_PUSHGATEWAY_URL=http://pushgateway:9091

# ── Scheduler de Rounds ───────────────────────────────────────────────────────
# Intervalo entre ciclos de verificação.
FL_SCHEDULER_INTERVAL_HOURS=6
# Quórum mínimo de clientes para disparar round.
FL_SCHEDULER_MIN_CLIENTS=3
# Limite máximo de rounds.
FL_SCHEDULER_MAX_ROUNDS=20
# Delta de acurácia para considerar estável.
FL_SCHEDULER_CONV_THRESHOLD=0.005
# Rounds estáveis consecutivos para convergir.
FL_SCHEDULER_CONV_PATIENCE=3
FL_SCHEDULER_TIMEZONE=America/Sao_Paulo
FL_SCHEDULER_LOG=logs/scheduler.log

# ── Banco de dados PostgreSQL (docker-compose.db.yml) ────────────────────────
# Suba o banco com:  docker compose -f docker-compose.db.yml up -d
#
# Obrigatório — usado pelo compose e pela API. Precisa bater exatamente com a
# senha embutida em FL_DB_URL abaixo (usado em Makefile:546,582-583 no create
# do container Docker — qualquer divergência quebra autenticação no db-up).
FL_DB_PASSWORD=senhaForte
# Porta exposta no host (mude se já estiver em uso).
FL_DB_PORT=5432

# URL de conexão — usada pelo SQLAlchemy na API e pelos clientes FL
FL_DB_URL=postgresql://mosaicfl:senhaForte@localhost:5432/mosaicfl

# ── Fonte de Dados ────────────────────────────────────────────────────────────
# Tipo de fonte: postgresql | sqlite | csv | synthetic
MOSAICFL_SOURCE_TYPE=synthetic

# Tabela/query usada quando MOSAICFL_SOURCE_TYPE=postgresql
FL_DB_TABLE=prontuarios
FL_DB_QUERY=SELECT * FROM prontuarios WHERE ativo = true

# CSV alternativo (usado quando MOSAICFL_SOURCE_TYPE=csv)
FL_CSV_PATH=data/minha_base.csv

# ── Configuração do Modelo (override dos defaults de config.py) ───────────────
FL_VOCAB_SIZE=10000
FL_SEQ_LEN=128
FL_BATCH_SIZE=16
# Amostras sintéticas quando source=synthetic.
FL_SIM_SAMPLES=1000

# ── RAG / LLM ────────────────────────────────────────────────────────────────
# Backend de geração LLM do módulo RAG.
#   ollama     → POST localhost:11434/api/generate (padrão para training-full)
#                Requer: ollama serve + ollama pull gemma3:4b
#   huggingface → AutoModelForCausalLM via transformers (DistilGPT-2 por padrão)
FL_LLM_BACKEND=ollama
FL_LLM_MODEL=gemma3:4b
# Modelo HuggingFace usado como fallback automático se Ollama não estiver acessível.
FL_LLM_HF_MODEL=distilgpt2

# ── Calibração pós-treinamento (calibration_mixin.py, InferenceEngine) ────────
# Método usado após convergência do modelo federado (Caminho B):
#   temperature — TemperatureScaler (Guo et al. 2017), padrão
#   isotonic    — IsotonicCalibrator OvR (Zadrozny & Elkan 2002)
#   auto        — ajusta os dois no conjunto de calibração, persiste o de menor ECE
FL_CALIBRATION_METHOD=temperature

# ── Orquestração de Runtime (config_loader.py) ───────────────────────────────
# Backend para leitura de config dinâmica antes de cada round:
#   chroma — ChromaDB (padrão; mesmo banco usado pelo RAG)
#   file   — arquivo JSON local em FL_LOG_DIR/runtime_config.json
FL_CONFIG_BACKEND=chroma

# Caminho do banco ChromaDB (compartilhado com RAG; padrão do rag_system_v2.py)
CHROMA_DB_PATH=./chroma_db

# Para atualizar config em runtime sem reiniciar o servidor (backend=chroma):
#   python -c "
#   from infrastructure.mosaicfl_server.config_loader import ChromaDBConfigLoader
#   ChromaDBConfigLoader().write({'proximal_mu': 0.005, 'pause_seconds': 0, 'stop': False})
#   "
