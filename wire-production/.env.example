# wire-production/.env.example
#
# Variáveis de ambiente para o ambiente wire-production do MOSAIC-FL.
# Copie para .env e ajuste conforme necessário:
#
#   cp .env.example .env
#   docker compose up --build
#
# Valores sem comentário são os padrões usados quando a variável não está
# definida. O docker-compose.yml usa ${VAR:-default} para todos os opcionais.

# ── Federação ──────────────────────────────────────────────────────────────

# Número de rounds de treinamento federado
# Wire-production padrão: 5 (rápido); produção real: 20-50
FL_NUM_ROUNDS=5

# Mínimo de clientes para iniciar um round
FL_MIN_CLIENTS=3

# Parâmetro proximal FedProx (regularização)
# 0.01 é o padrão; aumente para dados mais heterogêneos
FL_PROXIMAL_MU=0.01

# ── Scheduler ─────────────────────────────────────────────────────────────

# Intervalo entre verificações do scheduler (em horas)
# 0.017 ≈ 1 minuto — adequado para wire-production
# Produção real: 6.0 (a cada 6 horas)
FL_SCHEDULER_INTERVAL=0.017

# ── API ────────────────────────────────────────────────────────────────────

# Porta HTTP da API (exposta no host)
FL_API_PORT=8000

# Chave de autenticação para os endpoints protegidos.
# Vazio = modo desenvolvimento (sem autenticação).
# Em produção, defina uma chave forte:
#   FL_API_KEY=minha-chave-secreta-longa
FL_API_KEY=

# Origens CORS permitidas (separadas por vírgula)
# * = todas as origens (desenvolvimento)
# Em produção: FL_CORS_ORIGINS=https://meu-frontend.example.com
FL_CORS_ORIGINS=*

# ── Infraestrutura ─────────────────────────────────────────────────────────

# Porta gRPC do servidor Flower (exposta no host)
FL_SERVER_PORT=8080

# Formato de log: json (produção) | text (desenvolvimento)
FL_LOG_FORMAT=json
